NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
YOUTUBE_API_KEY=
# Optional: raises r.jina.ai rate limits for the Cloudflare-bypass fallback in /api/import-url
JINA_READER_API_KEY=
# Feature 09: Library Sharing
RESEND_API_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: sender address for library-sharing emails
EMAIL_FROM_ADDRESS=Rezept-App <noreply@rezept-app.de>
# Feature 13: Admin Dashboard — comma-separated allowlist of admin emails
# (case-insensitive, trimmed). Empty/unset → no admins. Configure in Vercel
# Environment Variables for production; setting it here only affects local dev.
ADMIN_EMAILS=
# Feature 13: Registration gate. "true" (default) blocks any email not present
# in the invited_emails table from registering. Flip to "false" to open
# registration. Admins manage the allowlist via the /settings admin section.
INVITE_ONLY_REGISTRATION=true
# Phase 2: Error monitoring (Sentry). All optional — without a DSN the SDK is
# a complete no-op. SENTRY_AUTH_TOKEN/ORG/PROJECT additionally enable
# source-map upload during builds (set them in Vercel, not locally).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Feature 14: Push notifications (Web Push / VAPID). Generate a key pair with:
#   npx web-push generate-vapid-keys
# Set all three in Vercel (production) AND here for local dev, then redeploy
# (the public key is build-time-inlined). Without them, push is a safe no-op.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
