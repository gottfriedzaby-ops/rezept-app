{
    "permissions": {
      "defaultMode": "auto"
    },
    "hooks": {
      "PostToolUse": [
        {
          "matcher": "Write|Edit",
          "hooks": [
            {
              "type": "command",
              "command": "bash /home/user/rezept-app/.claude/hooks/run-tests-on-ts-change.sh"
            }
          ]
        }
      ]
    },
    "enabledPlugins": {
      "supabase@claude-plugins-official": true,
      "frontend-design@claude-plugins-official": true,
      "typescript-lsp@claude-plugins-official": true,
      "github@claude-plugins-official": true,
      "vercel@claude-plugins-official": true,
      "standards@trendium-marketplace": true
    },
    "extraKnownMarketplaces": {
      "trendium-marketplace": {
        "source": {
          "source": "github",
          "repo": "Trendium-Labs/trendium-tool-claude-code"
        }
      },
        "xyz-marketplace": {
            "source": {
                "source": "github",
                "repo": "gottfriedzaby-ops/xyz"
}
    },
    "theme": "auto",
    "skipAutoPermissionPrompt": true
}
